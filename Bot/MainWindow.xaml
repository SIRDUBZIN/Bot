<Window x:Class="Bot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="750"
        Width="1300"
        FontFamily="Segoe UI">

    <Grid>


        <!-- 🌑 DARK OVERLAY -->
        <Rectangle Fill="#AA0A0F1F"/>

        <!-- LAYOUT GRID -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL -->
            <Border Background="#151B2D" Grid.Column="0">
                <StackPanel Margin="10">

                    <TextBlock Text="CYBER BOT"
                               Foreground="Cyan"
                               FontSize="20"
                               FontWeight="Bold"
                               TextAlignment="Center"/>

                    <TextBlock x:Name="QuizScoreText"
                               Text="0 / 15"
                               Foreground="White"
                               Margin="0,20,0,0"
                               TextAlignment="Center"/>

                    <TextBlock Text="MEMORY"
                               Foreground="Cyan"
                               Margin="0,20,0,0"/>

                    <TextBlock x:Name="MemoryTextBlock"
                               Text="No memory"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="LAST TOPIC"
                               Foreground="Cyan"
                               Margin="0,20,0,0"/>

                    <TextBlock x:Name="LastTopicText"
                               Text="None"
                               Foreground="White"/>

                </StackPanel>
            </Border>

            <!-- CHAT PANEL -->
            <Grid Grid.Column="1">

                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="10">

                    <Button Content="Start Quiz" Click="StartQuizButton_Click" Width="120"/>
                    <Button Content="Restart" Click="RestartQuizButton_Click" Width="120"/>
                    <Button Content="Show Log" Click="ShowLogButton_Click" Width="120"/>

                </StackPanel>

                <!-- CHAT -->
                <ScrollViewer Grid.Row="1" x:Name="ChatScrollViewer">
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>

                <!-- INPUT -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UserInputTextBox"
                             KeyDown="UserInputTextBox_KeyDown"/>

                    <Button Grid.Column="1"
                            Content="Send"
                            Click="SendButton_Click"/>

                </Grid>

            </Grid>

            <!-- RIGHT PANEL -->
            <Border Grid.Column="2" Background="#1E1E2F">
                <StackPanel Margin="10">

                    <TextBlock Text="TASKS" Foreground="Cyan"/>

                    <TextBox x:Name="TaskTextBox"/>
                    <Button Content="Add Task" Click="AddTaskButton_Click"/>

                    <ListBox x:Name="TaskListBox"/>

                    <TextBlock Text="ACTIVITY LOG"
                               Foreground="Cyan"
                               Margin="0,20,0,0"/>

                    <ListBox x:Name="ActivityLogListBox"/>

                </StackPanel>
            </Border>

        </Grid>
    </Grid>
</Window>